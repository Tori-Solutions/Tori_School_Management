<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_enrollment_teacher" model="ir.rule">
        <field name="name">Enrollment Teacher Own Classes</field>
        <field name="model_id" ref="model_tori_enrollment"/>
        <field name="groups" eval="[(4, ref('tori_school_management.group_education_teacher'))]"/>
        <field name="domain_force">[('class_id.teacher_id', '=', user.id)]</field>
    </record>

    <record id="rule_assignment_teacher" model="ir.rule">
        <field name="name">Assignment Teacher Own</field>
        <field name="model_id" ref="model_tori_assignment"/>
        <field name="groups" eval="[(4, ref('tori_school_management.group_education_teacher'))]"/>
        <field name="domain_force">[('teacher_id', '=', user.id)]</field>
    </record>

    <record id="rule_attendance_teacher" model="ir.rule">
        <field name="name">Attendance Teacher Own Classes</field>
        <field name="model_id" ref="model_tori_student_attendance"/>
        <field name="groups" eval="[(4, ref('tori_school_management.group_education_teacher'))]"/>
        <field name="domain_force">[('enrollment_id.class_id.teacher_id', '=', user.id)]</field>
    </record>

    <record id="rule_submission_student" model="ir.rule">
        <field name="name">Submission Student Own</field>
        <field name="model_id" ref="model_tori_submission"/>
        <field name="groups" eval="[(4, ref('tori_school_management.group_education_student'))]"/>
        <field name="domain_force">[('enrollment_id.student_id.user_ids', 'in', [user.id])]</field>
    </record>

    <record id="rule_enrollment_student" model="ir.rule">
        <field name="name">Enrollment Student Own</field>
        <field name="model_id" ref="model_tori_enrollment"/>
        <field name="groups" eval="[(4, ref('tori_school_management.group_education_student'))]"/>
        <field name="domain_force">[('student_id.user_ids', 'in', [user.id])]</field>
    </record>

    <record id="rule_enrollment_parent" model="ir.rule">
        <field name="name">Enrollment Parent Granted</field>
        <field name="model_id" ref="model_tori_enrollment"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('parent_id.user_ids', 'in', [user.id]), ('portal_access_granted', '=', True)]</field>
    </record>
</odoo>

