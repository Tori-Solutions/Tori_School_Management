<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tori_timetable_tree" model="ir.ui.view">
        <field name="name">tori.timetable.slot.tree</field>
        <field name="model">tori.timetable.slot</field>
        <field name="arch" type="xml">
            <list>
                <field name="class_id"/>
                <field name="section_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="day"/>
                <field name="start_time"/>
                <field name="end_time"/>
            </list>
        </field>
    </record>

    <record id="view_tori_timetable_form" model="ir.ui.view">
        <field name="name">tori.timetable.slot.form</field>
        <field name="model">tori.timetable.slot</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="class_id"/>
                        <field name="section_id"/>
                        <field name="subject_id"/>
                        <field name="teacher_id"/>
                        <field name="room_id"/>
                        <field name="day"/>
                        <field name="start_time"/>
                        <field name="end_time"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tori_timetable_calendar" model="ir.ui.view">
        <field name="name">tori.timetable.slot.calendar</field>
        <field name="model">tori.timetable.slot</field>
        <field name="arch" type="xml">
            <calendar string="Class Timetable" date_start="start_datetime" date_stop="end_datetime" color="teacher_id" event_limit="5" mode="week" quick_create="False">
                <field name="subject_id"/>
                <field name="class_id"/>
                <field name="room_id"/>
                <field name="teacher_id" filters="1" avatar_field="image_128"/>
            </calendar>
        </field>
    </record>

    <record id="action_tori_timetable" model="ir.actions.act_window">
        <field name="name">Timetable</field>
        <field name="res_model">tori.timetable.slot</field>
        <field name="view_mode">list,form,calendar</field>
    </record>

    <menuitem id="menu_tori_timetable" name="Timetable" parent="tori_school_management.menu_tori_school_academics" action="action_tori_timetable" sequence="10"/>
</odoo>


