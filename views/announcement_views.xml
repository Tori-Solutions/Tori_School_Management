<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_announcement_list" model="ir.ui.view">
        <field name="name">tori.announcement.list</field>
        <field name="model">tori.announcement</field>
        <field name="arch" type="xml">
            <list string="Announcements" default_order="date desc">
                <field name="date"/>
                <field name="title"/>
                <field name="audience" widget="badge"/>
                <field name="session_id"/>
            </list>
        </field>
    </record>

    <record id="view_announcement_form" model="ir.ui.view">
        <field name="name">tori.announcement.form</field>
        <field name="model">tori.announcement</field>
        <field name="arch" type="xml">
            <form string="Announcement">
                <sheet>
                    <group>
                        <group>
                            <field name="title"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="audience"/>
                            <field name="session_id"/>
                        </group>
                    </group>
                    <field name="body" widget="html" placeholder="Announcement content..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_announcement_search" model="ir.ui.view">
        <field name="name">tori.announcement.search</field>
        <field name="model">tori.announcement</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <filter string="Today" name="today" domain="[('date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="All Students" name="students" domain="[('audience','in',['all','students'])]"/>
                <filter string="All Teachers" name="teachers" domain="[('audience','in',['all','teachers'])]"/>
                <group>
                    <filter string="Audience" name="group_audience" context="{'group_by': 'audience'}"/>
                    <filter string="Session" name="group_session" context="{'group_by': 'session_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_announcement" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">tori.announcement</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
