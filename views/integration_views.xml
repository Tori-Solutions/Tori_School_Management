<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Partner Form View to add Smart Buttons for Students -->
    <record id="view_partner_form_tori" model="ir.ui.view">
        <field name="name">res.partner.form.tori</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <!-- Admissions Smart Button -->
                <button name="action_view_tori_applications" type="object" class="oe_stat_button" icon="fa-graduation-cap" invisible="not is_student">
                    <field name="tori_application_count" widget="statinfo" string="Admissions"/>
                </button>
                <!-- Enrollments Smart Button -->
                <button name="action_view_tori_enrollments" type="object" class="oe_stat_button" icon="fa-book" invisible="not is_student">
                    <field name="tori_enrollment_count" widget="statinfo" string="Enrollments"/>
                </button>
            </div>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_student"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Employee Form View to add Smart Buttons for Teachers -->
    <record id="view_employee_form_tori" model="ir.ui.view">
        <field name="name">hr.employee.form.tori</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <!-- Classes Smart Button -->
                <button name="action_view_tori_classes" type="object" class="oe_stat_button" icon="fa-users" invisible="not is_teacher">
                    <field name="tori_class_count" widget="statinfo" string="Classes"/>
                </button>
            </div>
            <!-- Add Is Teacher Checkbox -->
            <xpath expr="//field[@name='job_id']" position="after">
                <field name="is_teacher" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Account Move Form to show Fee Slip reference -->
    <record id="view_move_form_tori" model="ir.ui.view">
        <field name="name">account.move.form.tori</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="tori_fee_slip_id" invisible="not tori_fee_slip_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_list_tori_student" model="ir.ui.view">
        <field name="name">res.partner.list.tori.student</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tori_current_class_id" string="Class"/>
                <field name="tori_current_section_id" string="Section" optional="show"/>
                <field name="tori_current_session_id" string="Session"/>
                <field name="tori_current_enrollment_state" string="Status" widget="badge" decoration-success="tori_current_enrollment_state == 'active'" decoration-warning="tori_current_enrollment_state == 'inactive'" decoration-muted="tori_current_enrollment_state == 'graduated'" optional="show"/>
                <field name="phone" optional="show"/>
                <field name="email"/>
                <field name="city" optional="show"/>
                <field name="tori_application_count" string="Applications" optional="show"/>
                <field name="tori_enrollment_count" string="Enrollments" optional="show"/>
                <field name="active" optional="hide"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_partner_search_tori_student" model="ir.ui.view">
        <field name="name">res.partner.search.tori.student</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Student Database Search">
                <!-- Text search fields -->
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="city"/>
                <!-- Academic search fields -->
                <field name="tori_current_class_id" string="Class"/>
                <field name="tori_current_section_id" string="Section"/>
                <field name="tori_current_session_id" string="Session"/>
                <field name="state_id"/>
                <field name="country_id"/>
                <separator/>
                <!-- Enrollment status filters -->
                <filter name="student_only" string="Students" domain="[('is_student', '=', True)]"/>
                <filter name="enrollment_active" string="Active Enrollment" domain="[('tori_current_enrollment_state', '=', 'active')]"/>
                <filter name="enrollment_inactive" string="Inactive Enrollment" domain="[('tori_current_enrollment_state', '=', 'inactive')]"/>
                <filter name="enrollment_graduated" string="Graduated" domain="[('tori_current_enrollment_state', '=', 'graduated')]"/>
                <separator/>
                <!-- Admission / enrollment presence filters -->
                <filter name="with_admission" string="Has Application" domain="[('tori_application_count', '&gt;', 0)]"/>
                <filter name="with_enrollment" string="Enrolled" domain="[('tori_enrollment_count', '&gt;', 0)]"/>
                <filter name="without_enrollment" string="Not Enrolled" domain="[('tori_enrollment_count', '=', 0)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <!-- Group By -->
                <group name="group_by">
                    <filter name="group_class" string="Class" context="{'group_by': 'tori_current_class_id'}"/>
                    <filter name="group_section" string="Section" context="{'group_by': 'tori_current_section_id'}"/>
                    <filter name="group_session" string="Session" context="{'group_by': 'tori_current_session_id'}"/>
                    <filter name="group_status" string="Enrollment Status" context="{'group_by': 'tori_current_enrollment_state'}"/>
                    <filter name="group_city" string="City" context="{'group_by': 'city'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state_id'}"/>
                    <filter name="group_country" string="Country" context="{'group_by': 'country_id'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_created" string="Created On" context="{'group_by': 'create_date:month'}"/>
                </group>
                <!-- Search panel for sidebar facet drill-down -->
                <searchpanel>
                    <field name="tori_current_class_id" string="Class"/>
                    <field name="tori_current_section_id" string="Section"/>
                    <field name="tori_current_session_id" string="Session"/>
                    <field name="country_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_tori_student_database" model="ir.actions.act_window">
        <field name="name">Student Database</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_student', '=', True)]</field>
        <field name="search_view_id" ref="view_partner_search_tori_student"/>
        <field name="view_id" ref="view_partner_list_tori_student"/>
        <field name="context">{'search_default_student_only': 1}</field>
    </record>

    <menuitem id="menu_tori_student_database" name="Student Database" parent="tori_school_management.menu_tori_school_admission" action="action_tori_student_database" sequence="30"/>

</odoo>
