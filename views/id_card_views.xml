<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_id_card_list" model="ir.ui.view">
        <field name="name">tori.id.card.list</field>
        <field name="model">tori.id.card</field>
        <field name="arch" type="xml">
            <list string="ID Cards">
                <field name="enrollment_id"/>
                <field name="design_id"/>
                <field name="barcode"/>
            </list>
        </field>
    </record>

    <record id="view_id_card_form" model="ir.ui.view">
        <field name="name">tori.id.card.form</field>
        <field name="model">tori.id.card</field>
        <field name="arch" type="xml">
            <form string="ID Card">
                <sheet>
                    <group>
                        <field name="enrollment_id"/>
                        <field name="design_id"/>
                        <field name="barcode" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_id_card_design_list" model="ir.ui.view">
        <field name="name">tori.id.card.design.list</field>
        <field name="model">tori.id.card.design</field>
        <field name="arch" type="xml">
            <list string="ID Card Designs">
                <field name="name"/>
                <field name="orientation" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_id_card_design_form" model="ir.ui.view">
        <field name="name">tori.id.card.design.form</field>
        <field name="model">tori.id.card.design</field>
        <field name="arch" type="xml">
            <form string="ID Card Design">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="orientation"/>
                    </group>
                    <field name="template_html" widget="html"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_id_card" model="ir.actions.act_window">
        <field name="name">ID Cards</field>
        <field name="res_model">tori.id.card</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_id_card_design" model="ir.actions.act_window">
        <field name="name">ID Card Designs</field>
        <field name="res_model">tori.id.card.design</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
