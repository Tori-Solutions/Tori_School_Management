<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tori_session_tree" model="ir.ui.view">
        <field name="name">tori.session.tree</field>
        <field name="model">tori.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="branch_id"/>
            </list>
        </field>
    </record>

    <record id="view_tori_session_form" model="ir.ui.view">
        <field name="name">tori.session.form</field>
        <field name="model">tori.session</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="branch_id"/>
                    </group>
                    <notebook>
                        <page string="Academic Years">
                            <field name="academic_year_ids">
                                <list editable="bottom">
                                    <field name="title"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tori_session_search" model="ir.ui.view">
        <field name="name">tori.session.search</field>
        <field name="model">tori.session</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="session_in_progress" string="In Progress" domain="[('state','=','in_progress')]"/>
                <group name="group_by">
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_branch" string="Branch" context="{'group_by':'branch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_tori_academic_year_tree" model="ir.ui.view">
        <field name="name">tori.academic.year.tree</field>
        <field name="model">tori.academic.year</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="session_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <record id="view_tori_academic_year_form" model="ir.ui.view">
        <field name="name">tori.academic.year.form</field>
        <field name="model">tori.academic.year</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="session_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <field name="term_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="weightage"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tori_session" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">tori.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_tori_academic_year" model="ir.actions.act_window">
        <field name="name">Academic Years</field>
        <field name="res_model">tori.academic.year</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_tori_term" model="ir.actions.act_window">
        <field name="name">Terms</field>
        <field name="res_model">tori.term</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tori_session" name="Sessions" parent="tori_school_management.menu_tori_school_setup" action="action_tori_session" sequence="10"/>
    <menuitem id="menu_tori_academic_year" name="Academic Years" parent="tori_school_management.menu_tori_school_setup" action="action_tori_academic_year" sequence="20"/>
    <menuitem id="menu_tori_term" name="Terms" parent="tori_school_management.menu_tori_school_setup" action="action_tori_term" sequence="30"/>
</odoo>


