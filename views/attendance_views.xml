<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tori_attendance_tree" model="ir.ui.view">
        <field name="name">tori.student.attendance.tree</field>
        <field name="model">tori.student.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance" decoration-success="status == 'present'" decoration-danger="status == 'absent'" decoration-warning="status == 'late'" decoration-muted="status == 'excused'">
                <field name="enrollment_id"/>
                <field name="date"/>
                <field name="status" widget="badge" decoration-success="status == 'present'" decoration-danger="status == 'absent'" decoration-warning="status == 'late'"/>
                <field name="method" widget="badge"/>
                <field name="marked_by"/>
            </list>
        </field>
    </record>

    <record id="view_tori_attendance_form" model="ir.ui.view">
        <field name="name">tori.student.attendance.form</field>
        <field name="model">tori.student.attendance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="enrollment_id"/>
                        <field name="date"/>
                        <field name="timetable_slot_id"/>
                        <field name="status"/>
                        <field name="method"/>
                        <field name="marked_by"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tori_attendance_pivot" model="ir.ui.view">
        <field name="name">tori.student.attendance.pivot</field>
        <field name="model">tori.student.attendance</field>
        <field name="arch" type="xml">
            <pivot string="Attendance Analysis">
                <field name="date" type="row"/>
                <field name="status" type="col"/>
                <field name="id" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_tori_attendance_graph" model="ir.ui.view">
        <field name="name">tori.student.attendance.graph</field>
        <field name="model">tori.student.attendance</field>
        <field name="arch" type="xml">
            <graph string="Attendance Graph" type="bar">
                <field name="date" type="row"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_tori_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">tori.student.attendance</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <menuitem id="menu_tori_attendance" name="Attendance" parent="tori_school_management.menu_tori_school_academics" action="action_tori_attendance" sequence="20"/>
</odoo>


