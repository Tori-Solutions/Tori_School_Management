<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tori_scholarship_tree" model="ir.ui.view">
        <field name="name">tori.scholarship.tree</field>
        <field name="model">tori.scholarship</field>
        <field name="arch" type="xml">
            <list>
                <field name="enrollment_id"/>
                <field name="name"/>
                <field name="discount_type"/>
                <field name="percent_discount" optional="hide"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_tori_scholarship_form" model="ir.ui.view">
        <field name="name">tori.scholarship.form</field>
        <field name="model">tori.scholarship</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_mark_paid" type="object" string="Mark Paid" invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,paid"/>
                </header>
                <sheet>
                    <group>
                        <group string="Scholarship">
                            <field name="enrollment_id"/>
                            <field name="name"/>
                            <field name="discount_type"/>
                            <field name="amount" invisible="discount_type != 'fixed'"/>
                            <field name="percent_discount" invisible="discount_type != 'percent'"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group string="Applicability">
                            <field name="apply_scope"/>
                            <field name="fee_element_ids" widget="many2many_tags" invisible="apply_scope != 'selected'"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="vendor_bill_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tori_scholarship" model="ir.actions.act_window">
        <field name="name">Scholarships</field>
        <field name="res_model">tori.scholarship</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tori_scholarship" name="Scholarships" parent="tori_school_management.menu_tori_school_finance" action="action_tori_scholarship" sequence="30"/>
</odoo>


