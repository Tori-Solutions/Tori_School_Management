<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_lesson_plan_list" model="ir.ui.view">
        <field name="name">tori.lesson.plan.list</field>
        <field name="model">tori.lesson.plan</field>
        <field name="arch" type="xml">
            <list string="Lesson Plans" default_order="lesson_date desc">
                <field name="lesson_date"/>
                <field name="class_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="homework_count" string="Homeworks"/>
            </list>
        </field>
    </record>

    <record id="view_lesson_plan_form" model="ir.ui.view">
        <field name="name">tori.lesson.plan.form</field>
        <field name="model">tori.lesson.plan</field>
        <field name="arch" type="xml">
            <form string="Lesson Plan">
                <sheet>
                    <group>
                        <group string="Class">
                            <field name="class_id"/>
                            <field name="subject_id"/>
                        </group>
                        <group string="Teacher">
                            <field name="teacher_id"/>
                            <field name="lesson_date"/>
                        </group>
                    </group>
                    <group string="Content">
                        <field name="objectives" placeholder="Learning objectives for this lesson..."/>
                        <field name="content" widget="html"/>
                    </group>
                    <notebook>
                        <page string="Homework" name="homework">
                            <field name="homework_ids">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="deadline"/>
                                    <field name="attachment_ids" widget="many2many_tags"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lesson_plan_search" model="ir.ui.view">
        <field name="name">tori.lesson.plan.search</field>
        <field name="model">tori.lesson.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="class_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <filter string="Today" name="today" domain="[('lesson_date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Subject" name="group_subject" context="{'group_by': 'subject_id'}"/>
                    <filter string="Teacher" name="group_teacher" context="{'group_by': 'teacher_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_lesson_plan" model="ir.actions.act_window">
        <field name="name">Lesson Plans</field>
        <field name="res_model">tori.lesson.plan</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
