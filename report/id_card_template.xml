<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_id_card_document">
        <t t-call="web.external_layout">
            <div class="page">
                <h2>ID Card</h2>
                <p>
                    <strong>Student:</strong>
                    <span t-field="doc.enrollment_id.student_id"/>
                </p>
                <p>
                    <strong>Class:</strong>
                    <span t-field="doc.enrollment_id.class_id"/>
                </p>
                <p>
                    <strong>Barcode:</strong>
                    <span t-field="doc.barcode"/>
                </p>
                <div t-if="doc.enrollment_id.student_id.image_1920">
                    <img t-att-src="image_data_uri(doc.enrollment_id.student_id.image_1920)" style="max-height: 120px;"/>
                </div>
            </div>
        </t>
    </template>

    <record id="action_report_id_card" model="ir.actions.report">
        <field name="name">ID Card</field>
        <field name="model">tori.id.card</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tori_school_management.report_id_card_document</field>
        <field name="report_file">tori_school_management.report_id_card_document</field>
    </record>
</odoo>

